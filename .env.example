# ============================================================
# Portfolio Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file to GitHub!
# ============================================================

# Flask Secret Key (generate a long random string)
# You can generate one at: https://randomkeygen.com/
SECRET_KEY=your-super-secret-key-change-this-immediately

# MySQL Database (use a hosted provider like Railway or Aiven for production)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=portfolio_db

# Admin Dashboard Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123_ChangeThis!

# Flask Environment (development or production)
FLASK_ENV=development
